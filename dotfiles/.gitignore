# ============================================================================
# SECRETS — never commit these. Sync them via rsync (scripts/04) instead.
# ============================================================================
opencode/auth.json
opencode/**/auth.json
claude/**/.credentials.json
claude/**/credentials.json
claude/**/*.token
claude/**/*.key
**/.env
**/.env.*
!**/.env.example

# ============================================================================
# OpenCode build artifacts — installed locally per machine, never sync
# ============================================================================
opencode/node_modules/
opencode/package.json
opencode/package-lock.json
opencode/bun.lock
opencode/.gitignore

# ============================================================================
# EPHEMERAL / per-machine Claude Code state — don't sync across Macs
# ============================================================================
claude/backups/
claude/cache/
claude/caches/
claude/downloads/
claude/file-history/
claude/history.jsonl
claude/ide/
claude/logs/
claude/mcp-needs-auth-cache.json
claude/plugins/
claude/policy-limits.json
claude/projects/
claude/session-env/
claude/sessions/
claude/shell-snapshots/
claude/statsig/
claude/telemetry/
claude/todos/
claude/__store.db*

# ============================================================================
# Shell history & session state
# ============================================================================
shell/.zsh_history
shell/.bash_history
shell/.lesshst
shell/.viminfo

# ============================================================================
# OS / editor junk
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
*.swp
*.swo
*~
